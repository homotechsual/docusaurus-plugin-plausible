{
  "name": "@homotechsual/docusaurus-plugin-plausible",
  "version": "1.0.0",
  "description": "A Docusaurus plugin for adding Plausible analytics to your Docusaurus site",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "files": [
    "lib/**/*.js",
    "lib/**/*.js.map",
    "lib/**/*.d.ts",
    "lib/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "eslint src",
    "format": "prettier --write 'src/**/*.ts'",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/homotechsual/docusaurus-plugin-plausible.git"
  },
  "keywords": [
    "docusaurus",
    "docusaurus-plugin",
    "plausible",
    "analytics"
  ],
  "author": "Mikey O'Toole <mikey@homotechsual.dev>",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/homotechsual/docusaurus-plugin-plausible/issues"
  },
  "homepage": "https://github.com/homotechsual/docusaurus-plugin-plausible#readme",
  "peerDependencies": {
    "@docusaurus/core": ">=3.0.0 <5.0.0",
    "@mdx-js/react": ">=3.0.0",
    "react": "~19.2.7",
    "react-dom": "~19.2.7"
  },
  "devDependencies": {
    "@docusaurus/core": "^3.10.1",
    "@docusaurus/module-type-aliases": "^3.10.1",
    "@docusaurus/types": "^3.10.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "packageManager": "yarn@4.16.0+sha512.5374c94eb4ef6aa8188fb112f20c1aa6569f248d676c5e576e1fd2a1a4d8d87a96df65d9dfe1c2a0252cbe38bda46cf18d955005b81b43cc7607a5c9d56fd2b6",
  "workspaces": [
    "demo"
  ],
  "publishConfig": {
    "access": "public"
  }
}
